<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/DefaultView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/extra_scroll_space_large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
            <com.garethevans.church.opensongtablet.customviews.ExposedDropDown
                android:id="@+id/themeName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_gravity="center_vertical"
                android:gravity="center_vertical"
                android:hint="@string/theme_choose" />
                <com.garethevans.church.opensongtablet.customviews.MyFAB
                    android:id="@+id/resetTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/reset_colours"
                    android:src="@drawable/refresh"/>
            </LinearLayout>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSwitch
                android:id="@+id/invertPDF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/invert_PDF"
                android:hint="@string/invert_PDF_info"/>

            <LinearLayout
                android:id="@+id/customElementLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/section_box"
                android:orientation="vertical"
                android:padding="16dp">

                <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/custom_theme_builder" />

                <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:text="@string/cryo_section_colors"
                    app:size="small" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center">
                    <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                        android:id="@+id/chipVerse"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        app:showLabel="false"/>
                    <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                        android:id="@+id/chipChorus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        app:showLabel="false"/>
                    <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                        android:id="@+id/chipBridge"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        app:showLabel="false"/>
                    <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                        android:id="@+id/chipPreChorus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        app:showLabel="false"/>
                    <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                        android:id="@+id/chipTag"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        app:showLabel="false"/>
                </LinearLayout>

                <com.garethevans.church.opensongtablet.customviews.ExposedDropDown
                    android:id="@+id/elementPicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/select_element" />

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/customColorButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/pick_color" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/section_box"
                android:orientation="vertical"
                android:padding="16dp">

                <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/main_song_display" />

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/lyricsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lyrics"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/chordsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/chords"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/capoButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/capo_chords"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/multilingualButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/multilingual"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/pageButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/background"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/section_box"
                android:orientation="vertical"
                android:padding="16dp">

                <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/section_highlighting" />

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/verseButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/verse"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/chorusButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/chorus"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/prechorusButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/prechorus"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/bridgeButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/bridge"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/tagButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tag"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/commentButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/comment"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/customButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/custom"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/titleHighlighting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/title"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/chordHighlighting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/chords"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/section_box"
                android:orientation="vertical"
                android:padding="16dp">

                <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                    android:id="@+id/presenterStageMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/presenter_mode" />

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/presoButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/text"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/presoChordButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/chords"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/presoCapoButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/capo"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/presoMultilingualButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/multilingual"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/presoInfoButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/info_text"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/presoAlertButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/alert"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/presoShadowButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/block_text_shadow"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/section_box"
                android:orientation="vertical"
                android:padding="16dp">

                <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/song_features" />

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/metronomeButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/metronome"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/hotZoneButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/hot_zones"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/section_box"
                android:orientation="vertical"
                android:padding="16dp">

                <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/song_notes" />

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/stickytextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/text"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/stickybackgroundButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/background"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/section_box"
                android:orientation="vertical"
                android:padding="16dp">

                <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/music_score_popup" />

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/abctextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/text"/>

                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/abcbackgroundButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/background"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>