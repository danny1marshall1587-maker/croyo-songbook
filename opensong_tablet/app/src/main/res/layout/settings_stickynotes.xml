<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/DefaultView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/extra_scroll_space_large">

        <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
            android:id="@+id/edit"
            style="@style/largeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/edit" />

        <com.garethevans.church.opensongtablet.customviews.MyMaterialEditText
            android:id="@+id/stickyNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:hint="@string/song_notes"
            android:imeOptions="actionNone"
            android:inputType="textMultiLine"
            android:lines="6"
            android:minLines="6"
            app:endIconMode="clear_text" />

        <com.garethevans.church.opensongtablet.customviews.MyMaterialButton
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/save" />

        <com.garethevans.church.opensongtablet.customviews.MyDivider style="@style/MyDividerLine" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                android:id="@+id/settingsGlobal"
                style="@style/largeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings" />

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSwitch
                android:id="@+id/autoShowSticky"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/autoshow_stickynotes" />

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSlider
                android:id="@+id/timeSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/autohide_time"
                android:value="0"
                android:valueFrom="0"
                android:valueTo="100" />

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSlider
                android:id="@+id/alphaSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/alpha"
                android:value="80"
                android:valueFrom="50"
                android:valueTo="100" />


            <com.garethevans.church.opensongtablet.customviews.MyMaterialSlider
                android:id="@+id/stickyTextSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/text_size"
                android:value="14"
                android:valueFrom="8"
                android:valueTo="32" />


            <com.garethevans.church.opensongtablet.customviews.MyMaterialSlider
                android:id="@+id/stickyWidth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="100"
                android:text="@string/width"
                android:value="400"
                android:valueFrom="100"
                android:valueTo="1200" />

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                android:id="@+id/settingsLocal"
                style="@style/largeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings" />

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="0dp"
                android:text="@string/override_sticky" />

            <com.garethevans.church.opensongtablet.customviews.TextThreeSlider
                android:id="@+id/settingsOverrideStickySlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:paddingTop="0dp"
                app:textC="@string/override_on"
                app:textL="@string/override_none"
                app:textR="@string/override_off" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>