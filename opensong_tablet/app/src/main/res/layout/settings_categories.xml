<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/DefaultView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="@dimen/extra_scroll_space_large">

            <!-- Section 1: Prompter & AI -->
            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PROMPTER &amp; AI"
                android:textStyle="bold"
                app:size="large"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/modeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/choose_app_mode"
                android:hint="@string/performance_mode"
                android:drawableStart="@drawable/account"
                app:size="medium"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/cryoButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cryo_performance"
                android:hint="@string/cryo_prompter"
                android:drawableStart="@drawable/bullseye"
                app:size="medium"/>

            <!-- Section 2: Display & Themes -->
            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DISPLAY &amp; THEMES"
                android:textStyle="bold"
                app:size="large"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/displayButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/display"
                android:hint="@string/display_settings"
                android:drawableStart="@drawable/projector"
                app:size="medium"/>

            <!-- Section 3: Library & Storage -->
            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LIBRARY &amp; STORAGE"
                android:textStyle="bold"
                app:size="large"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/storageButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/storage"
                android:hint="@string/storage_options_info"
                android:drawableStart="@drawable/folder_open"
                app:size="medium"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/actionsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/song_actions"
                android:hint="@string/song_actions_description"
                android:drawableStart="@drawable/music_note"
                app:size="medium"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/setActionsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/set_manage"
                android:hint="@string/set_manage_info"
                android:drawableStart="@drawable/inline_set"
                app:size="medium"/>

            <!-- Section 4: Connections & Input -->
            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONNECTIONS &amp; INPUT"
                android:textStyle="bold"
                app:size="large"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/gesturesButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/controls"
                android:hint="@string/controls_description"
                android:drawableStart="@drawable/pedal"
                app:size="medium"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/connectButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/connections_connect"
                android:hint="@string/connections_description"
                android:drawableStart="@drawable/share"
                app:size="medium"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/webServerButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/web_server"
                android:hint="@string/web_server_hint"
                android:drawableStart="@drawable/web"
                app:size="medium"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/midiButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/midi"
                android:hint="@string/midi_description"
                android:drawableStart="@drawable/midi"
                app:size="medium"/>

            <!-- Section 5: Account & Help -->
            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACCOUNT &amp; HELP"
                android:textStyle="bold"
                app:size="large"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/profilesButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile"
                android:hint="@string/profile_explanation"
                android:drawableStart="@drawable/account"
                app:size="medium"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/ccliButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ccli"
                android:hint="@string/ccli_description"
                android:drawableStart="@drawable/book"
                app:size="medium"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/utilitiesButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/utilities"
                android:hint="@string/utilities_info"
                android:drawableStart="@drawable/settings"
                app:size="medium"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/aboutButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about"
                android:hint="@string/about_description"
                android:drawableStart="@drawable/information"
                app:size="medium"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>