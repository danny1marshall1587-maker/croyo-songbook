<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/draggableView"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:alpha="1"
    android:animateLayoutChanges="true"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/mainTools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp">

        <com.garethevans.church.opensongtablet.customviews.MyImageView
            android:id="@+id/dragIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_margin="4dp"
            android:contentDescription="@string/move_from"
            android:focusable="false"
            app:srcCompat="@drawable/drag" />

        <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
            android:id="@+id/currentTool"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:contentDescription="@string/tool"
            app:backgroundTint="@color/transparent"
            app:borderWidth="0dp"
            app:elevation="0dp"
            app:fabSize="mini"
            android:src="@drawable/pen" />

        <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
            android:id="@+id/saveButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:contentDescription="@string/save"
            app:backgroundTint="@color/transparent"
            app:borderWidth="0dp"
            app:elevation="0dp"
            app:fabSize="mini"
            android:src="@drawable/save" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/toolSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tool" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                android:id="@+id/penFAB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_margin="2dp"
                android:contentDescription="@string/highlight"
                app:backgroundTint="@color/transparent"
                app:borderWidth="0dp"
                app:elevation="0dp"
                app:fabSize="mini"
                android:src="@drawable/pen" />

            <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                android:id="@+id/highlighterFAB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_margin="2dp"
                android:contentDescription="@string/highlight"
                app:backgroundTint="@color/transparent"
                app:borderWidth="0dp"
                app:elevation="0dp"
                app:fabSize="mini"
                android:src="@drawable/highlighter" />

            <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                android:id="@+id/eraserFAB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_margin="2dp"
                android:contentDescription="@string/highlight"
                app:backgroundTint="@color/transparent"
                app:borderWidth="0dp"
                app:elevation="0dp"
                app:fabSize="mini"
                android:src="@drawable/eraser" />

            <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                android:id="@+id/undoFAB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_margin="2dp"
                android:contentDescription="@string/highlight"
                app:backgroundTint="@color/transparent"
                app:borderWidth="0dp"
                app:elevation="0dp"
                app:fabSize="mini"
                android:src="@drawable/undo" />

            <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                android:id="@+id/redoFAB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_margin="2dp"
                android:contentDescription="@string/highlight"
                app:backgroundTint="@color/transparent"
                app:borderWidth="0dp"
                app:elevation="0dp"
                app:fabSize="mini"
                android:src="@drawable/redo" />

            <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                android:id="@+id/deleteFAB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_margin="2dp"
                android:contentDescription="@string/highlight"
                app:backgroundTint="@color/transparent"
                app:borderWidth="0dp"
                app:elevation="0dp"
                app:fabSize="mini"
                android:src="@drawable/delete" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical">

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSlider
                android:id="@+id/sizeSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/size"
                android:valueFrom="1"
                android:valueTo="50" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/colorsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical">

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/color_choose" />


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                    android:id="@+id/color_black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:contentDescription="@string/color_choose"
                    app:backgroundTint="@color/black"
                    app:borderWidth="0dp"
                    app:elevation="0dp"
                    app:fabSize="mini" />

                <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                    android:id="@+id/color_white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:contentDescription="@string/color_choose"
                    app:backgroundTint="@color/white"
                    app:borderWidth="0dp"
                    app:elevation="0dp"
                    app:fabSize="mini" />

                <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                    android:id="@+id/color_yellow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:contentDescription="@string/color_choose"
                    app:backgroundTint="@color/yellow"
                    app:borderWidth="0dp"
                    app:elevation="0dp"
                    app:fabSize="mini" />

                <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                    android:id="@+id/color_red"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:contentDescription="@string/color_choose"
                    app:backgroundTint="@color/red"
                    app:borderWidth="0dp"
                    app:elevation="0dp"
                    app:fabSize="mini" />

                <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                    android:id="@+id/color_green"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:contentDescription="@string/color_choose"
                    app:backgroundTint="@color/green"
                    app:borderWidth="0dp"
                    app:elevation="0dp"
                    app:fabSize="mini" />

                <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                    android:id="@+id/color_blue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:contentDescription="@string/color_choose"
                    app:backgroundTint="@color/blue"
                    app:borderWidth="0dp"
                    app:elevation="0dp"
                    app:fabSize="mini" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>