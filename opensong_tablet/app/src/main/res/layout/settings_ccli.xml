<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/DefaultView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/extra_scroll_space_large">

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSwitch
                android:id="@+id/ccliAutomatic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ccli_automatic"
                app:size="large"/>
            <com.garethevans.church.opensongtablet.customviews.MyDivider
                style="@style/MyDividerLine"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/ccliChurch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/ccli_church"
                android:text="@string/ccli_church"
                app:size="large"/>
            <com.garethevans.church.opensongtablet.customviews.MyDivider
                style="@style/MyDividerLine"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/ccliLicence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/ccli_licence"
                android:text="@string/ccli_licence"
                app:size="large" />
            <com.garethevans.church.opensongtablet.customviews.MyDivider
                style="@style/MyDividerLine"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/ccliView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/ccli_log"
                android:text="@string/ccli_view"
                app:size="large" />
            <com.garethevans.church.opensongtablet.customviews.MyDivider
                style="@style/MyDividerLine"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/ccliExportCSV"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/csv"
                android:text="@string/export"
                app:size="large" />
            <com.garethevans.church.opensongtablet.customviews.MyDivider
                style="@style/MyDividerLine"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/ccliDelete"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/ccli_reset"
                android:text="@string/delete"
                app:size="large" />
            <com.garethevans.church.opensongtablet.customviews.MyDivider
                style="@style/MyDividerLine"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>