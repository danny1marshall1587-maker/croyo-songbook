<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/DefaultView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/extra_scroll_space">

        <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/downloadBible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/bible_download_for_offline"
                android:text="@string/download"
                app:size="large"/>
            <com.garethevans.church.opensongtablet.customviews.MyDivider
                style="@style/MyDividerLine"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/bibleOffline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/bible_browse_offline"
                android:text="@string/bible_browse"
                app:size="large"/>
            <com.garethevans.church.opensongtablet.customviews.MyDivider
                style="@style/MyDividerLine"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialTextView
                android:id="@+id/bibleGateway"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/search_biblegateway"
                android:text="@string/bible_browse"
                app:size="large"/>
            <com.garethevans.church.opensongtablet.customviews.MyDivider
                style="@style/MyDividerLine"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>