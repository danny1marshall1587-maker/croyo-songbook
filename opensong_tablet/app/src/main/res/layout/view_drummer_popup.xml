<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/popup_bg">

    <LinearLayout
            android:id="@+id/dealWithAudioLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <com.garethevans.church.opensongtablet.customviews.DialogHeader
            android:id="@+id/dialogHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:minHeight="96dp"
                android:orientation="horizontal"
                android:padding="16dp"
                android:baselineAligned="true">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                        android:id="@+id/drummerPlayStop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:contentDescription="@string/preview"
                        android:src="@drawable/play"
                        app:fabSize="mini" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                        android:id="@+id/drummerFill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:contentDescription="@string/delete"
                        android:src="@drawable/star"
                        app:fabSize="mini" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                        android:id="@+id/drummerTransition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:contentDescription="@string/save"
                        android:src="@drawable/swap"
                        app:fabSize="mini" />
                </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <com.garethevans.church.opensongtablet.customviews.MyFloatingActionButton
                    android:id="@+id/drummerSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:contentDescription="@string/save"
                    android:src="@drawable/settings"
                    app:fabSize="mini" />
            </FrameLayout>
            </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>