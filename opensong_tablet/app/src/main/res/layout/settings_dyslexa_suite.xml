<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/DefaultView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="@dimen/extra_scroll_space_large">

            <!-- Section 1: Prompter -->
            <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DYSLEXA PROMPTER"
                android:textStyle="bold"
                app:size="large"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSwitch
                android:id="@+id/dyslexaPrompterEnable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dyslexa_prompter"
                android:hint="@string/dyslexa_prompter_info"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                android:id="@+id/prompterScaleLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/active_line_scale"
                android:textStyle="bold"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSlider
                android:id="@+id/prompterScaleSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="1.0"
                android:valueTo="2.0"
                android:stepSize="0.1" />

            <com.garethevans.church.opensongtablet.customviews.MyDivider style="@style/MyDividerLine" />

            <!-- Section 2: Flow Animation -->
            <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FLOW ANIMATION"
                android:textStyle="bold"
                app:size="large"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSwitch
                android:id="@+id/dyslexaFlowEnable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dyslexa_flow_enable"/>

            <com.garethevans.church.opensongtablet.customviews.ExposedDropDown
                android:id="@+id/dyslexaFlowPattern"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/dyslexa_flow_pattern"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">
                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/flowPrimaryColor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dyslexa_flow_color_primary"/>
                <com.garethevans.church.opensongtablet.customviews.ThemeItemColor
                    android:id="@+id/flowSecondaryColor"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/dyslexa_flow_color_secondary"/>
            </LinearLayout>

            <com.garethevans.church.opensongtablet.customviews.MyDivider style="@style/MyDividerLine" />

            <!-- Section 3: Face Gestures -->
            <com.garethevans.church.opensongtablet.customviews.MyMaterialSimpleTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FACE GESTURES"
                android:textStyle="bold"
                app:size="large"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"/>

            <com.garethevans.church.opensongtablet.customviews.MyMaterialSwitch
                android:id="@+id/faceGestureEnable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/face_gesture_flip"
                android:hint="@string/face_gesture_flip_info"/>

            <LinearLayout
                android:id="@+id/faceGestureDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.garethevans.church.opensongtablet.customviews.ExposedDropDown
                    android:id="@+id/gestureMouthOpen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Mouth Open Action" />

                <com.garethevans.church.opensongtablet.customviews.ExposedDropDown
                    android:id="@+id/gestureNod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Head Nod Action" />

                <com.garethevans.church.opensongtablet.customviews.ExposedDropDown
                    android:id="@+id/gestureRaise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Head Raise Action" />

                <com.garethevans.church.opensongtablet.customviews.ExposedDropDown
                    android:id="@+id/gestureEyebrows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Eyebrows Raise Action" />

                <com.garethevans.church.opensongtablet.customviews.ExposedDropDown
                    android:id="@+id/gestureWinkLeft"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Wink Left Action" />

                <com.garethevans.church.opensongtablet.customviews.ExposedDropDown
                    android:id="@+id/gestureWinkRight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Wink Right Action" />

            </LinearLayout>

            <com.garethevans.church.opensongtablet.customviews.MyDivider 
                style="@style/MyDividerLine"
                android:layout_marginBottom="200dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
