#!/bin/bash
# Cryo-Prompter: Automated Build Environment for Fedora
# Designed for fresh installs on All-In-One build machines.

echo "--- Initializing Cryo-Prompter Build Environment (Fedora) ---"

# 1. Update and Install Core Dependencies
sudo dnf update -y
sudo dnf install -y java-17-openjdk-devel wget unzip git libstdc++.i686 glibc.i686 ncurses-libs.i686

# 2. Setup Android SDK Directory
export ANDROID_HOME=$HOME/Android/Sdk
mkdir -p $ANDROID_HOME/cmdline-tools
cd $ANDROID_HOME/cmdline-tools

# 3. Download official Command Line Tools
if [ ! -d "latest" ]; then
    echo "Fetching Android Command Line Tools..."
    wget https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip -O tools.zip
    unzip tools.zip
    mv cmdline-tools latest
    rm tools.zip
fi

# 4. Persistence for Environment Variables
export PATH=$PATH:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools
if ! grep -q "ANDROID_HOME" ~/.bashrc; then
    echo "export ANDROID_HOME=$HOME/Android/Sdk" >> ~/.bashrc
    echo "export PATH=\$PATH:\$ANDROID_HOME/cmdline-tools/latest/bin:\$ANDROID_HOME/platform-tools" >> ~/.bashrc
fi

# 5. Install Required SDK components and NDK (Oboe C++)
echo "Installing Android 33, Build Tools, and NDK 25..."
yes | $ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --sdk_root=$ANDROID_HOME "platform-tools" "platforms;android-33" "build-tools;33.0.2" "ndk;25.1.8937393"

# 6. Final Build Command
echo "--- Compiling Production APK ---"
# Note: Antigravity agent will navigate to the project directory before running this
chmod +x gradlew
./gradlew assembleDebug

echo "--- Build Complete: app/build/outputs/apk/debug/app-debug.apk ---"
